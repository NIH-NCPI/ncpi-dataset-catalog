# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.js

# testing
/coverage
/test-results/*

# catalog files
/files/ncpi-catalog
/catalog/dbgap-selected-publications.json
/catalog/grant-publications.json
/catalog/pmc-citations.json

# classification pipeline output (generated, mostly gitignored)
# Files needed by the backend Docker build are un-ignored below.
/catalog-build/classification/output/*
!/catalog-build/classification/output/concept-embeddings.npy
!/catalog-build/classification/output/concept-embeddings.sha256
!/catalog-build/classification/output/concept-isa.json
!/catalog-build/classification/output/concept-vocabulary.json
!/catalog-build/classification/output/demographic-profiles.json
!/catalog-build/classification/output/llm-concepts-v4/
!/catalog-build/classification/output/ncpi-categories.json
!/catalog-build/classification/output/phenx-concept-vocabulary.json

# classification source data (copied from external pipeline)
/catalog-build/classification/source/

# dbGaP variable XML files (672 MB, re-downloadable via npm run update-dbgap-source)
/catalog-build/source/dbgap-variables/

# UMLS data (large download + generated db)
/catalog-build/source/umls/2025*/
/catalog-build/source/umls/*.db

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.tmp
/downloads/*

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

#System Files
.DS_Store
Thumbs.db

# env files
.env
.env*.local
/.env.development
/.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo

# IDEs and editors
.idea
/.vscode
.obsidian

# hygen
_templates

# nvm
.nvmrc

# favicons
/public/favicons/*

# python
__pycache__/
*.egg-info/
/analytics/**/venv/
.ipynb_checkpoints/
*.duckdb

!.gitkeep

# claude
.claude/rules*

# vscode
.vscode/*

#api
/public/api*